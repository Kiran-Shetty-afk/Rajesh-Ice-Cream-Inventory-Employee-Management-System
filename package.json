{
  "name": "rajesh-icecream-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Offline desktop inventory and employee management system for Rajesh Icecream.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"next dev --webpack\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:web": "next dev --webpack",
    "build": "npm run db:prepare && next build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "start": "electron .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:prepare": "prisma db push --skip-generate && npm run db:seed",
    "db:seed": "tsx prisma/seed.ts",
    "backup": "tsx scripts/backup.ts",
    "lint": "eslint .", "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "electron-is-dev": "3.0.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "10.5.2",
    "concurrently": "10.0.3",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "8.5.17",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.10",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "com.rajesh.icecream.manager",
    "productName": "Rajesh Icecream",
    "directories": {
      "output": "release"
    },
    "files": [
      ".next/**/*",
      "dist-electron/**/*",
      "package.json",
      "prisma/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Rajesh-Icecream-Setup-${version}.${ext}"
    }
  }
}
