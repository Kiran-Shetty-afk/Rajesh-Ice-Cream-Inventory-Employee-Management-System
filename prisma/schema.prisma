generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  INACTIVE
}

model Product {
  id               String            @id @default(cuid())
  name             String
  category         String
  flavor           String
  unitPrice        Float
  factoryQuantity  Int               @default(0)
  lowStockQuantity Int               @default(10)
  status           ProductStatus     @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shopStocks       ShopInventory[]
  transferItems    StockTransferItem[]
  dailySaleItems   DailySaleItem[]

  @@index([name])
  @@index([category])
  @@index([flavor])
}

model RawMaterial {
  id               String   @id @default(cuid())
  name             String
  unit             String
  quantity         Float    @default(0)
  unitCost         Float
  lowStockQuantity Float    @default(0)
  supplier         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Shop {
  id             String           @id @default(cuid())
  name           String
  managerName    String?
  mobileNumber   String?
  address        String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stocks         ShopInventory[]
  transfers      StockTransfer[]
  dailySales     DailySale[]

  @@index([name])
}

model ShopInventory {
  id        String   @id @default(cuid())
  shopId    String
  productId String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
}

model StockTransfer {
  id          String              @id @default(cuid())
  shopId      String
  transferNo  String              @unique
  transferDate DateTime           @default(now())
  note        String?
  createdAt   DateTime            @default(now())
  shop        Shop                @relation(fields: [shopId], references: [id])
  items       StockTransferItem[]

  @@index([transferDate])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Int
  unitPrice  Float
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model Employee {
  id            String         @id @default(cuid())
  employeeCode  String         @unique
  name          String
  mobileNumber  String
  address       String?
  joiningDate   DateTime
  monthlySalary Float
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  loans         EmployeeLoan[]

  @@index([name])
  @@index([status])
}

model EmployeeLoan {
  id         String   @id @default(cuid())
  employeeId String
  amount     Float
  loanDate   DateTime
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([loanDate])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BackupLog {
  id        String   @id @default(cuid())
  fileName  String
  filePath  String
  kind      String
  createdAt DateTime @default(now())
}

model DailySale {
  id            String          @id @default(cuid())
  shopId        String
  date          DateTime
  totalAmount   Float
  totalQuantity Int
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  shop          Shop            @relation(fields: [shopId], references: [id])
  items         DailySaleItem[]

  @@index([date])
}

model DailySaleItem {
  id          String    @id @default(cuid())
  dailySaleId String
  productId   String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  wastage     Int       @default(0)
  returned    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  dailySale   DailySale @relation(fields: [dailySaleId], references: [id], onDelete: Cascade)
}
