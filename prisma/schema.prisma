generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  INACTIVE
}

model Product {
  id               String            @id @default(cuid())
  name             String
  category         String
  flavor           String
  unitPrice        Float
  factoryQuantity  Int               @default(0)
  lowStockQuantity Int               @default(10)
  status           ProductStatus     @default(ACTIVE)
  mfgDate          DateTime?
  expiryDate       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  
  shopStocks       ShopInventory[]
  transferItems    StockTransferItem[]
  dailySaleItems   DailySaleItem[]
  purchaseItems    PurchaseItem[]
  wastages         Wastage[]

  @@index([name])
  @@index([category])
  @@index([flavor])
}

model RawMaterial {
  id               String   @id @default(cuid())
  name             String
  unit             String
  quantity         Float    @default(0)
  unitCost         Float
  lowStockQuantity Float    @default(0)
  supplier         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Shop {
  id             String           @id @default(cuid())
  name           String
  managerName    String?
  mobileNumber   String?
  address        String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  stocks         ShopInventory[]
  transfers      StockTransfer[]
  dailySales     DailySale[]
  wastages       Wastage[]

  @@index([name])
}

model ShopInventory {
  id         String    @id @default(cuid())
  shopId     String
  productId  String
  quantity   Int       @default(0)
  mfgDate    DateTime?
  expiryDate DateTime?
  updatedAt  DateTime  @updatedAt
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
}

model StockTransfer {
  id          String              @id @default(cuid())
  shopId      String
  transferNo  String              @unique
  transferDate DateTime           @default(now())
  note        String?
  attachmentPath String?
  createdAt   DateTime            @default(now())
  shop        Shop                @relation(fields: [shopId], references: [id])
  items       StockTransferItem[]

  @@index([transferDate])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Int
  unitPrice  Float
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model Employee {
  id            String         @id @default(cuid())
  employeeCode  String         @unique
  name          String
  mobileNumber  String
  address       String?
  joiningDate   DateTime
  monthlySalary Float
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  loans         EmployeeLoan[]

  @@index([name])
  @@index([status])
}

model EmployeeLoan {
  id         String   @id @default(cuid())
  employeeId String
  amount     Float
  loanDate   DateTime
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([loanDate])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model BackupLog {
  id        String   @id @default(cuid())
  fileName  String
  filePath  String
  kind      String
  createdAt DateTime @default(now())
}

model DailySale {
  id            String          @id @default(cuid())
  shopId        String
  date          DateTime
  totalAmount   Float
  totalQuantity Int
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  shop          Shop            @relation(fields: [shopId], references: [id])
  items         DailySaleItem[]

  @@index([date])
}

model DailySaleItem {
  id          String    @id @default(cuid())
  dailySaleId String
  productId   String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  wastage     Int       @default(0)
  returned    Int       @default(0)
  product     Product   @relation(fields: [productId], references: [id])
  dailySale   DailySale @relation(fields: [dailySaleId], references: [id], onDelete: Cascade)
}

model Supplier {
  id            String     @id @default(cuid())
  name          String
  contactNumber String?
  gstNumber     String?
  address       String?
  paymentDue    Float      @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
}

model Purchase {
  id            String         @id @default(cuid())
  supplierId    String
  invoiceNumber String         @unique
  purchaseDate  DateTime
  totalAmount   Float
  note          String?
  attachmentPath String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  supplier      Supplier       @relation(fields: [supplierId], references: [id])
  items         PurchaseItem[]

  @@index([purchaseDate])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  productId   String
  quantity    Int
  costPrice   Float
  totalPrice  Float
  mfgDate     DateTime?
  expiryDate  DateTime?
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
}

model Wastage {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  shopId      String?  // null if factory wastage
  productId   String
  quantity    Int
  reason      String?
  cost        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shop        Shop?    @relation(fields: [shopId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  
  @@index([date])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // e.g. LOW_STOCK, EXPIRY, BACKUP
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
